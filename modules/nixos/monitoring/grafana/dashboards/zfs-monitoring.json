{
  "id": null,
  "uid": "zfs-pool-monitoring",
  "title": "ZFS Pool Monitoring",
  "tags": [
    "zfs",
    "storage",
    "monitoring"
  ],
  "timezone": "browser",
  "schemaVersion": 36,
  "editable": true,
  "version": 3,
  "refresh": "30s",
  "style": "dark",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "zpool",
        "type": "query",
        "label": "ZFS Pool",
        "datasource": null,
        "query": "label_values(node_zfs_zpool_state, zpool)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "\ud83c\udfca Pool State",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pool State",
      "description": "Each possible state is shown. The active one has value 1.",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "node_zfs_zpool_state{zpool=~\"$zpool\"}",
          "legendFormat": "{{state}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 1,
                "color": "green"
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "degraded"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "faulted|unavail|offline|removed|suspended"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Pool State History",
      "description": "1 = pool was in this state. Watch for degraded/faulted/suspended spikes.",
      "gridPos": {
        "h": 4,
        "w": 18,
        "x": 6,
        "y": 1
      },
      "targets": [
        {
          "expr": "node_zfs_zpool_state{zpool=~\"$zpool\", state=\"online\"}",
          "legendFormat": "online {{zpool}}"
        },
        {
          "expr": "node_zfs_zpool_state{zpool=~\"$zpool\", state=\"degraded\"}",
          "legendFormat": "degraded {{zpool}}"
        },
        {
          "expr": "node_zfs_zpool_state{zpool=~\"$zpool\", state=\"faulted\"}",
          "legendFormat": "faulted {{zpool}}"
        },
        {
          "expr": "node_zfs_zpool_state{zpool=~\"$zpool\", state=\"suspended\"}",
          "legendFormat": "suspended {{zpool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": "online.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "degraded.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "(faulted|suspended).*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 4,
      "type": "row",
      "title": "\ud83d\udcc1 Dataset I/O",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Dataset IOPS",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "expr": "rate(node_zfs_zpool_dataset_reads{zpool=~\"$zpool\"}[5m])",
          "legendFormat": "Reads {{dataset}}"
        },
        {
          "expr": "rate(node_zfs_zpool_dataset_writes{zpool=~\"$zpool\"}[5m])",
          "legendFormat": "Writes {{dataset}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "iops"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Dataset Bandwidth",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "targets": [
        {
          "expr": "rate(node_zfs_zpool_dataset_nread{zpool=~\"$zpool\"}[5m])",
          "legendFormat": "Read {{dataset}}"
        },
        {
          "expr": "rate(node_zfs_zpool_dataset_nwritten{zpool=~\"$zpool\"}[5m])",
          "legendFormat": "Write {{dataset}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Dataset File Activity (links/unlinks)",
      "description": "nunlinks = file deletes, nunlinked = completed deletes",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "targets": [
        {
          "expr": "rate(node_zfs_zpool_dataset_nunlinks{zpool=~\"$zpool\"}[5m])",
          "legendFormat": "Unlinks/s {{dataset}}"
        },
        {
          "expr": "rate(node_zfs_zpool_dataset_nunlinked{zpool=~\"$zpool\"}[5m])",
          "legendFormat": "Unlinked/s {{dataset}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Dataset ZIL Commit Rate",
      "description": "ZIL commits per dataset. High commit counts with stalls indicate sync write pressure.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "targets": [
        {
          "expr": "rate(node_zfs_zpool_dataset_zil_commit_count{zpool=~\"$zpool\"}[5m])",
          "legendFormat": "Commits/s {{dataset}}"
        },
        {
          "expr": "rate(node_zfs_zpool_dataset_zil_commit_stall_count{zpool=~\"$zpool\"}[5m])",
          "legendFormat": "Stalls/s {{dataset}}"
        },
        {
          "expr": "rate(node_zfs_zpool_dataset_zil_commit_error_count{zpool=~\"$zpool\"}[5m])",
          "legendFormat": "Errors/s {{dataset}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 9,
      "type": "row",
      "title": "\ud83e\udde0 ARC (Adaptive Replacement Cache)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 22
      }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "ARC Size",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 0,
        "y": 23
      },
      "targets": [
        {
          "expr": "node_zfs_arc_size",
          "legendFormat": "ARC Size"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "ARC Max",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 4,
        "y": 23
      },
      "targets": [
        {
          "expr": "node_zfs_arc_c_max",
          "legendFormat": "ARC Max"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "ARC Min",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 8,
        "y": 23
      },
      "targets": [
        {
          "expr": "node_zfs_arc_c_min",
          "legendFormat": "ARC Min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "ARC Target",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 12,
        "y": 23
      },
      "targets": [
        {
          "expr": "node_zfs_arc_c",
          "legendFormat": "ARC Target"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "ARC Data",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 16,
        "y": 23
      },
      "targets": [
        {
          "expr": "node_zfs_arc_data_size",
          "legendFormat": "ARC Data"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 15,
      "type": "stat",
      "title": "ARC Metadata",
      "gridPos": {
        "h": 3,
        "w": 4,
        "x": 20,
        "y": 23
      },
      "targets": [
        {
          "expr": "node_zfs_arc_metadata_size",
          "legendFormat": "ARC Metadata"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 16,
      "type": "gauge",
      "title": "ARC Hit Ratio",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 0,
        "y": 26
      },
      "targets": [
        {
          "expr": "rate(node_zfs_arc_hits[5m]) / (rate(node_zfs_arc_hits[5m]) + rate(node_zfs_arc_misses[5m])) * 100",
          "legendFormat": "Hit %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 70,
                "color": "yellow"
              },
              {
                "value": 90,
                "color": "green"
              }
            ]
          }
        }
      },
      "options": {
        "showThresholdMarkers": true
      }
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "ARC Hits vs Misses",
      "gridPos": {
        "h": 5,
        "w": 10,
        "x": 4,
        "y": 26
      },
      "targets": [
        {
          "expr": "rate(node_zfs_arc_hits[5m])",
          "legendFormat": "Total Hits"
        },
        {
          "expr": "rate(node_zfs_arc_misses[5m])",
          "legendFormat": "Total Misses"
        },
        {
          "expr": "rate(node_zfs_arc_demand_data_hits[5m])",
          "legendFormat": "Demand Data Hits"
        },
        {
          "expr": "rate(node_zfs_arc_demand_metadata_hits[5m])",
          "legendFormat": "Demand Metadata Hits"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "ARC MRU / MFU Size",
      "description": "MRU = Most Recently Used, MFU = Most Frequently Used. Healthy ARC balances both.",
      "gridPos": {
        "h": 5,
        "w": 10,
        "x": 14,
        "y": 26
      },
      "targets": [
        {
          "expr": "node_zfs_arc_mru_size",
          "legendFormat": "MRU"
        },
        {
          "expr": "node_zfs_arc_mfu_size",
          "legendFormat": "MFU"
        },
        {
          "expr": "node_zfs_arc_mru_ghost_size",
          "legendFormat": "MRU Ghost"
        },
        {
          "expr": "node_zfs_arc_mfu_ghost_size",
          "legendFormat": "MFU Ghost"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "ARC Size Over Time",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 31
      },
      "targets": [
        {
          "expr": "node_zfs_arc_size",
          "legendFormat": "Total"
        },
        {
          "expr": "node_zfs_arc_c_max",
          "legendFormat": "Max (c_max)"
        },
        {
          "expr": "node_zfs_arc_c_min",
          "legendFormat": "Min (c_min)"
        },
        {
          "expr": "node_zfs_arc_c",
          "legendFormat": "Target (c)"
        },
        {
          "expr": "node_zfs_arc_data_size",
          "legendFormat": "Data"
        },
        {
          "expr": "node_zfs_arc_metadata_size",
          "legendFormat": "Metadata"
        },
        {
          "expr": "node_zfs_arc_anon_size",
          "legendFormat": "Anon"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Prefetch Hits vs Misses",
      "description": "High prefetch miss rate means prefetcher is not predicting access patterns well.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 31
      },
      "targets": [
        {
          "expr": "rate(node_zfs_arc_prefetch_data_hits[5m])",
          "legendFormat": "Data Hits"
        },
        {
          "expr": "rate(node_zfs_arc_prefetch_data_misses[5m])",
          "legendFormat": "Data Misses"
        },
        {
          "expr": "rate(node_zfs_arc_prefetch_metadata_hits[5m])",
          "legendFormat": "Metadata Hits"
        },
        {
          "expr": "rate(node_zfs_arc_prefetch_metadata_misses[5m])",
          "legendFormat": "Metadata Misses"
        },
        {
          "expr": "rate(node_zfs_arc_demand_hit_predictive_prefetch[5m])",
          "legendFormat": "Predictive Hits"
        },
        {
          "expr": "rate(node_zfs_arc_demand_hit_prescient_prefetch[5m])",
          "legendFormat": "Prescient Hits"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 21,
      "type": "row",
      "title": "\ud83d\udcdd ZIL (ZFS Intent Log)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 39
      }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "ZIL Commit Activity",
      "description": "commit_count = sync writes committed. stall = waiting on ZIL. suspend = ZIL suspended (serious).",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 40
      },
      "targets": [
        {
          "expr": "rate(node_zfs_zil_zil_commit_count[5m])",
          "legendFormat": "Commits/s"
        },
        {
          "expr": "rate(node_zfs_zil_zil_commit_writer_count[5m])",
          "legendFormat": "Writers/s"
        },
        {
          "expr": "rate(node_zfs_zil_zil_commit_stall_count[5m])",
          "legendFormat": "Stalls/s"
        },
        {
          "expr": "rate(node_zfs_zil_zil_commit_suspend_count[5m])",
          "legendFormat": "Suspends/s"
        },
        {
          "expr": "rate(node_zfs_zil_zil_commit_error_count[5m])",
          "legendFormat": "Errors/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "ZIL Transaction Bytes",
      "description": "itx_copied = small writes copied into ZIL. itx_needcopy = larger writes. itx_indirect = indirect.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 40
      },
      "targets": [
        {
          "expr": "rate(node_zfs_zil_zil_itx_copied_bytes[5m])",
          "legendFormat": "Copied Bytes/s"
        },
        {
          "expr": "rate(node_zfs_zil_zil_itx_needcopy_bytes[5m])",
          "legendFormat": "Needcopy Bytes/s"
        },
        {
          "expr": "rate(node_zfs_zil_zil_itx_indirect_bytes[5m])",
          "legendFormat": "Indirect Bytes/s"
        },
        {
          "expr": "rate(node_zfs_zil_zil_itx_metaslab_normal_bytes[5m])",
          "legendFormat": "Metaslab Normal Bytes/s"
        },
        {
          "expr": "rate(node_zfs_zil_zil_itx_metaslab_slog_bytes[5m])",
          "legendFormat": "Metaslab SLOG Bytes/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 24,
      "type": "row",
      "title": "\ud83d\udcbe Disk Space (mounted datasets)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 48
      }
    },
    {
      "id": 25,
      "type": "gauge",
      "title": "ZFS Dataset Space Used %",
      "description": "Space usage per mounted ZFS dataset via node_filesystem metrics.",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 49
      },
      "targets": [
        {
          "expr": "100 * (node_filesystem_size_bytes{fstype=\"zfs\"} - node_filesystem_avail_bytes{fstype=\"zfs\"}) / node_filesystem_size_bytes{fstype=\"zfs\"}",
          "legendFormat": "{{mountpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 70,
                "color": "yellow"
              },
              {
                "value": 85,
                "color": "orange"
              },
              {
                "value": 95,
                "color": "red"
              }
            ]
          }
        }
      },
      "options": {
        "showThresholdMarkers": true,
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 26,
      "type": "timeseries",
      "title": "ZFS Dataset Free Space Over Time",
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 8,
        "y": 49
      },
      "targets": [
        {
          "expr": "node_filesystem_avail_bytes{fstype=\"zfs\"}",
          "legendFormat": "Free {{mountpoint}}"
        },
        {
          "expr": "node_filesystem_size_bytes{fstype=\"zfs\"}",
          "legendFormat": "Total {{mountpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    }
  ]
}

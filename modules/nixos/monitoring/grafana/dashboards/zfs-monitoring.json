{
  "id": null,
  "uid": "zfs-pool-monitoring",
  "title": "ZFS Pool Monitoring",
  "tags": [
    "zfs",
    "storage",
    "monitoring"
  ],
  "timezone": "browser",
  "schemaVersion": 36,
  "editable": true,
  "version": 1,
  "refresh": "30s",
  "style": "dark",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "pool",
        "type": "query",
        "label": "ZFS Pool",
        "datasource": null,
        "query": "label_values(node_zfs_zpool_size_bytes, pool)",
        "refresh": 2,
        "includeAll": true,
        "multi": false,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "\ud83c\udfca Pool Health Overview",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Pool State",
      "description": "0=ONLINE, 1=DEGRADED, 2=FAULTED, 3=OFFLINE, 4=UNAVAIL, 5=REMOVED",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "node_zfs_zpool_state{pool=~\"$pool\"}",
          "legendFormat": "{{pool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "ONLINE",
                  "color": "green"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "DEGRADED",
                  "color": "orange"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "2": {
                  "text": "FAULTED",
                  "color": "red"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "3": {
                  "text": "OFFLINE",
                  "color": "red"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "4": {
                  "text": "UNAVAIL",
                  "color": "red"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "5": {
                  "text": "REMOVED",
                  "color": "red"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 1,
                "color": "orange"
              },
              {
                "value": 2,
                "color": "red"
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pool Size",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "targets": [
        {
          "expr": "node_zfs_zpool_size_bytes{pool=~\"$pool\"}",
          "legendFormat": "{{pool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Space Used",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "targets": [
        {
          "expr": "node_zfs_zpool_allocated_bytes{pool=~\"$pool\"}",
          "legendFormat": "{{pool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "percentage",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 70,
                "color": "yellow"
              },
              {
                "value": 85,
                "color": "orange"
              },
              {
                "value": 95,
                "color": "red"
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Space Free",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "expr": "node_zfs_zpool_free_bytes{pool=~\"$pool\"}",
          "legendFormat": "{{pool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Fragmentation",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "targets": [
        {
          "expr": "node_zfs_zpool_fragmentation{pool=~\"$pool\"}",
          "legendFormat": "{{pool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 0.3,
                "color": "yellow"
              },
              {
                "value": 0.6,
                "color": "red"
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Dedup Ratio",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "targets": [
        {
          "expr": "node_zfs_zpool_dedupratio{pool=~\"$pool\"}",
          "legendFormat": "{{pool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2
        }
      }
    },
    {
      "id": 7,
      "type": "gauge",
      "title": "Pool Space Usage %",
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "expr": "100 * node_zfs_zpool_allocated_bytes{pool=~\"$pool\"} / node_zfs_zpool_size_bytes{pool=~\"$pool\"}",
          "legendFormat": "{{pool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 70,
                "color": "yellow"
              },
              {
                "value": 85,
                "color": "orange"
              },
              {
                "value": 95,
                "color": "red"
              }
            ]
          }
        }
      },
      "options": {
        "showThresholdMarkers": true
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Pool Space Over Time",
      "gridPos": {
        "h": 6,
        "w": 18,
        "x": 6,
        "y": 5
      },
      "targets": [
        {
          "expr": "node_zfs_zpool_allocated_bytes{pool=~\"$pool\"}",
          "legendFormat": "Used {{pool}}"
        },
        {
          "expr": "node_zfs_zpool_free_bytes{pool=~\"$pool\"}",
          "legendFormat": "Free {{pool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "type": "row",
      "title": "\u26a1 Pool I/O Performance",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 11
      },
      "id": 101
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Pool Read/Write Operations",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "expr": "rate(node_zfs_zpool_reads_total{pool=~\"$pool\"}[5m])",
          "legendFormat": "Reads {{pool}}"
        },
        {
          "expr": "rate(node_zfs_zpool_writes_total{pool=~\"$pool\"}[5m])",
          "legendFormat": "Writes {{pool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "iops"
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Pool Read/Write Bandwidth",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "targets": [
        {
          "expr": "rate(node_zfs_zpool_nread_bytes{pool=~\"$pool\"}[5m])",
          "legendFormat": "Read Bytes {{pool}}"
        },
        {
          "expr": "rate(node_zfs_zpool_nwritten_bytes{pool=~\"$pool\"}[5m])",
          "legendFormat": "Written Bytes {{pool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Pool Wait Times",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "expr": "rate(node_zfs_zpool_read_wait_ns{pool=~\"$pool\"}[5m])",
          "legendFormat": "Read Wait {{pool}}"
        },
        {
          "expr": "rate(node_zfs_zpool_write_wait_ns{pool=~\"$pool\"}[5m])",
          "legendFormat": "Write Wait {{pool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ns"
        }
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Pool Sync Waits",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "targets": [
        {
          "expr": "rate(node_zfs_zpool_sync_reads_total{pool=~\"$pool\"}[5m])",
          "legendFormat": "Sync Reads {{pool}}"
        },
        {
          "expr": "rate(node_zfs_zpool_sync_writes_total{pool=~\"$pool\"}[5m])",
          "legendFormat": "Sync Writes {{pool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "iops"
        }
      }
    },
    {
      "type": "row",
      "title": "\ud83e\udde0 ARC Cache",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "id": 102
    },
    {
      "id": 20,
      "type": "stat",
      "title": "ARC Size",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 29
      },
      "targets": [
        {
          "expr": "node_zfs_arc_size_bytes",
          "legendFormat": "ARC Size"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 21,
      "type": "gauge",
      "title": "ARC Hit Ratio",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 29
      },
      "targets": [
        {
          "expr": "rate(node_zfs_arc_hits_total[5m]) / (rate(node_zfs_arc_hits_total[5m]) + rate(node_zfs_arc_misses_total[5m])) * 100",
          "legendFormat": "Hit Ratio"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 70,
                "color": "yellow"
              },
              {
                "value": 90,
                "color": "green"
              }
            ]
          }
        }
      }
    },
    {
      "id": 22,
      "type": "stat",
      "title": "ARC Max Size",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 29
      },
      "targets": [
        {
          "expr": "node_zfs_arc_max_size_bytes",
          "legendFormat": "ARC Max"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 23,
      "type": "stat",
      "title": "ARC Min Size",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 29
      },
      "targets": [
        {
          "expr": "node_zfs_arc_min_size_bytes",

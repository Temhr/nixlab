{
  "id": null,
  "uid": "zfs-pool-monitoring",
  "title": "ZFS Pool Monitoring",
  "tags": [
    "zfs",
    "storage",
    "monitoring"
  ],
  "timezone": "browser",
  "schemaVersion": 36,
  "editable": true,
  "version": 2,
  "refresh": "30s",
  "style": "dark",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "zpool",
        "type": "query",
        "label": "ZFS Pool",
        "datasource": null,
        "query": "label_values(node_zfs_zpool_reads, zpool)",
        "refresh": 2,
        "includeAll": true,
        "multi": false,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "\ud83c\udfca Pool State",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pool State",
      "description": "Shows 1 for the active state. Green=online, Orange=degraded, Red=faulted/unavail.",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "node_zfs_pool_state{pool=~\"$zpool\"}",
          "legendFormat": "{{pool}} - {{state}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 1,
                "color": "green"
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "inactive",
                  "color": "text"
                }
              }
            },
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "ACTIVE",
                  "color": "green"
                }
              }
            }
          ]
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "online - 1"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "degraded.*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "(faulted|unavail|offline|removed|suspended).*"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Pool State History",
      "description": "Value=1 means the pool was in that state. Watch for degraded/faulted appearing.",
      "gridPos": {
        "h": 4,
        "w": 20,
        "x": 4,
        "y": 1
      },
      "targets": [
        {
          "expr": "node_zfs_pool_state{pool=~\"$zpool\", state=\"online\"}",
          "legendFormat": "{{pool}} online"
        },
        {
          "expr": "node_zfs_pool_state{pool=~\"$zpool\", state=\"degraded\"}",
          "legendFormat": "{{pool}} degraded"
        },
        {
          "expr": "node_zfs_pool_state{pool=~\"$zpool\", state=\"faulted\"}",
          "legendFormat": "{{pool}} faulted"
        },
        {
          "expr": "node_zfs_pool_state{pool=~\"$zpool\", state=\"suspended\"}",
          "legendFormat": "{{pool}} suspended"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 1
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "online"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "solid"
                }
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "degraded"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": "(faulted|suspended)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 4,
      "type": "row",
      "title": "\u26a1 Pool I/O Performance",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Pool IOPS (reads/writes per second)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "targets": [
        {
          "expr": "rate(node_zfs_zpool_reads{zpool=~\"$zpool\"}[5m])",
          "legendFormat": "Reads {{zpool}}"
        },
        {
          "expr": "rate(node_zfs_zpool_writes{zpool=~\"$zpool\"}[5m])",
          "legendFormat": "Writes {{zpool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "iops"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Pool Bandwidth (bytes/s)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "targets": [
        {
          "expr": "rate(node_zfs_zpool_nread{zpool=~\"$zpool\"}[5m])",
          "legendFormat": "Read {{zpool}}"
        },
        {
          "expr": "rate(node_zfs_zpool_nwritten{zpool=~\"$zpool\"}[5m])",
          "legendFormat": "Write {{zpool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Pool Wait Time (ns/s \u2014 proxy for latency)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "targets": [
        {
          "expr": "rate(node_zfs_zpool_wtime{zpool=~\"$zpool\"}[5m])",
          "legendFormat": "Write Wait ns/s {{zpool}}"
        },
        {
          "expr": "rate(node_zfs_zpool_rtime{zpool=~\"$zpool\"}[5m])",
          "legendFormat": "Read Wait ns/s {{zpool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ns"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Pool Queue Depth",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "targets": [
        {
          "expr": "node_zfs_zpool_wcnt{zpool=~\"$zpool\"}",
          "legendFormat": "Write Queue {{zpool}}"
        },
        {
          "expr": "node_zfs_zpool_rcnt{zpool=~\"$zpool\"}",
          "legendFormat": "Read Queue {{zpool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 9,
      "type": "row",
      "title": "\ud83e\udde0 ARC (Adaptive Replacement Cache)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 22
      }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "ARC Current Size",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 23
      },
      "targets": [
        {
          "expr": "node_zfs_arcstats_size_bytes",
          "legendFormat": "ARC Size"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "ARC Max Size",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 23
      },
      "targets": [
        {
          "expr": "node_zfs_arcstats_c_max_bytes",
          "legendFormat": "ARC Max"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "ARC Min Size",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 23
      },
      "targets": [
        {
          "expr": "node_zfs_arcstats_c_min_bytes",
          "legendFormat": "ARC Min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 13,
      "type": "gauge",
      "title": "ARC Hit Ratio",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 23
      },
      "targets": [
        {
          "expr": "rate(node_zfs_arcstats_hits_total[5m]) / (rate(node_zfs_arcstats_hits_total[5m]) + rate(node_zfs_arcstats_misses_total[5m])) * 100",
          "legendFormat": "Hit Ratio"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 70,
                "color": "yellow"
              },
              {
                "value": 90,
                "color": "green"
              }
            ]
          }
        }
      },
      "options": {
        "showThresholdMarkers": true
      }
    },
    {
      "id": 14,
      "type": "stat",
      "title": "ARC Data Size",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 23
      },
      "targets": [
        {
          "expr": "node_zfs_arcstats_data_bytes",
          "legendFormat": "Data"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 15,
      "type": "stat",
      "title": "ARC Metadata Size",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 23
      },
      "targets": [
        {
          "expr": "node_zfs_arcstats_metadata_size_bytes",
          "legendFormat": "Metadata"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "ARC Hits vs Misses",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 27
      },
      "targets": [
        {
          "expr": "rate(node_zfs_arcstats_hits_total[5m])",
          "legendFormat": "Hits"
        },
        {
          "expr": "rate(node_zfs_arcstats_misses_total[5m])",
          "legendFormat": "Misses"
        },
        {
          "expr": "rate(node_zfs_arcstats_demand_data_hits_total[5m])",
          "legendFormat": "Demand Data Hits"
        },
        {
          "expr": "rate(node_zfs_arcstats_demand_data_misses_total[5m])",
          "legendFormat": "Demand Data Misses"
        },
        {
          "expr": "rate(node_zfs_arcstats_prefetch_data_hits_total[5m])",
          "legendFormat": "Prefetch Hits"
        },
        {
          "expr": "rate(node_zfs_arcstats_prefetch_data_misses_total[5m])",
          "legendFormat": "Prefetch Misses"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "ARC Size Over Time",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 27
      },
      "targets": [
        {
          "expr": "node_zfs_arcstats_size_bytes",
          "legendFormat": "Total ARC"
        },
        {
          "expr": "node_zfs_arcstats_c_max_bytes",
          "legendFormat": "Max (c_max)"
        },
        {
          "expr": "node_zfs_arcstats_c_min_bytes",
          "legendFormat": "Min (c_min)"
        },
        {
          "expr": "node_zfs_arcstats_data_bytes",
          "legendFormat": "Data"
        },
        {
          "expr": "node_zfs_arcstats_metadata_size_bytes",
          "legendFormat": "Metadata"
        },
        {
          "expr": "node_zfs_arcstats_anon_size_bytes",
          "legendFormat": "Anon"
        },
        {
          "expr": "node_zfs_arcstats_mru_size_bytes",
          "legendFormat": "MRU"
        },
        {
          "expr": "node_zfs_arcstats_mfu_size_bytes",
          "legendFormat": "MFU"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 18,
      "type": "row",
      "title": "\ud83d\udcdd ZIL (ZFS Intent Log)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 35
      }
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "ZIL Commit Rate",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 36
      },
      "targets": [
        {
          "expr": "rate(node_zfs_zil_zil_itx_count_total[5m])",
          "legendFormat": "Transactions/s"
        },
        {
          "expr": "rate(node_zfs_zil_zil_commit_count_total[5m])",
          "legendFormat": "Commits/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "ZIL Write Bytes",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 36
      },
      "targets": [
        {
          "expr": "rate(node_zfs_zil_zil_itx_write_bytes_total[5m])",
          "legendFormat": "Write Bytes/s"
        },
        {
          "expr": "rate(node_zfs_zil_zil_itx_copied_bytes_total[5m])",
          "legendFormat": "Copied Bytes/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 21,
      "type": "row",
      "title": "\ud83d\udcc1 Dataset I/O (per-dataset)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 44
      }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Dataset Read/Write Ops",
      "description": "Per-dataset I/O from /proc/spl/kstat/zfs/POOL/objset-*. Label 'dataset' shows the dataset path.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 45
      },
      "targets": [
        {
          "expr": "rate(node_zfs_zpool_dataset_reads_total{zpool=~\"$zpool\"}[5m])",
          "legendFormat": "Reads {{dataset}}"
        },
        {
          "expr": "rate(node_zfs_zpool_dataset_writes_total{zpool=~\"$zpool\"}[5m])",
          "legendFormat": "Writes {{dataset}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "iops"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Dataset Read/Write Bytes",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 45
      },
      "targets": [
        {
          "expr": "rate(node_zfs_zpool_dataset_nread_bytes_total{zpool=~\"$zpool\"}[5m])",
          "legendFormat": "Read {{dataset}}"
        },
        {
          "expr": "rate(node_zfs_zpool_dataset_nwritten_bytes_total{zpool=~\"$zpool\"}[5m])",
          "legendFormat": "Write {{dataset}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 24,
      "type": "row",
      "title": "\ud83d\udcbe Disk Space (via filesystem metrics)",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 53
      }
    },
    {
      "id": 25,
      "type": "timeseries",
      "title": "ZFS Dataset Mounted Space Usage",
      "description": "Uses node_filesystem_* metrics. Only shows ZFS datasets that are mounted. Filters fstype=zfs.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 54
      },
      "targets": [
        {
          "expr": "100 * (node_filesystem_size_bytes{fstype=\"zfs\"} - node_filesystem_avail_bytes{fstype=\"zfs\"}) / node_filesystem_size_bytes{fstype=\"zfs\"}",
          "legendFormat": "Used% {{mountpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 70,
                "color": "yellow"
              },
              {
                "value": 85,
                "color": "orange"
              },
              {
                "value": 95,
                "color": "red"
              }
            ]
          }
        }
      }
    },
    {
      "id": 26,
      "type": "timeseries",
      "title": "ZFS Dataset Free Space",
      "description": "Free bytes per mounted ZFS dataset.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 54
      },
      "targets": [
        {
          "expr": "node_filesystem_avail_bytes{fstype=\"zfs\"}",
          "legendFormat": "Free {{mountpoint}}"
        },
        {
          "expr": "node_filesystem_size_bytes{fstype=\"zfs\"}",
          "legendFormat": "Total {{mountpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    }
  ]
}

#!/usr/bin/env bash
# bash_prompt — two-line prompt with time, job count, hostname, path, random emoji

# Only apply in interactive shells
[[ $- != *i* ]] && return

_PROMPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

# Load emoji list from file (single whitespace-separated line)
read -ra _EMOJIS <<< "$(cat "${_PROMPT_DIR}/emoticons")"

# Returns a random emoji from the loaded list
_random_emoji() {
    echo "${_EMOJIS[RANDOM % ${#_EMOJIS[@]}]}"
}

# ANSI 256-colour codes (wrapped in \[ \] so readline counts width correctly)
_CLR_BRACKET="\[\033[38;5;35m\]"
_CLR_CLOCK="\[\033[38;5;35m\]"
_CLR_JOBS="\[\033[38;5;33m\]"
_CLR_PATH="\[\033[38;5;33m\]"
_CLR_RESET="\[\033[0m\]"

# Rebuild PS1 before each command so time and exit code stay current
_set_prompt() {
    local _last=$?
    local _exit_indicator=""

    # Show exit code if last command failed
    [[ $_last -ne 0 ]] && _exit_indicator="❌($_last) "

    PS1="$_CLR_CLOCK\t "
    PS1+="$_CLR_BRACKET[${_CLR_JOBS}\j${_CLR_BRACKET}] "
    PS1+="${_exit_indicator}\H: ${_CLR_PATH}\w${_CLR_RESET} [$(_random_emoji)]\n"
    PS1+="|# "
}

PROMPT_COMMAND="_set_prompt"

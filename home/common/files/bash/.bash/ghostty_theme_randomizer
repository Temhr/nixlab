# ghostty_theme_randomizer — picks a random Ghostty theme on each shell reload

_ghostty_config="$HOME/.config/ghostty/config"
_ghostty_themes="$HOME/.bash/ghostty_themes.txt"

# Bail out safely if ghostty_themes file is missing
if [ ! -f "$_ghostty_themes" ]; then
    echo "Warning: ghostty_themes.txt not found, skipping theme randomizer."
    unset _ghostty_config _ghostty_themes
    return
fi

# Load themes into array and pick one at random
mapfile -t _themes < "$_ghostty_themes"
_rantheme="${_themes[$((RANDOM % ${#_themes[@]}))]}"

# Back up current config then write new one
\cp -f "$_ghostty_config" "${_ghostty_config}.bak"
{
    echo "background = 000000"
    echo "theme = $_rantheme"
} > "$_ghostty_config"

unset _ghostty_config _ghostty_themes _themes _rantheme
